#include <stdio.h>

struct Point {
    int x, y;
};

int main() {
    struct Point p[] = {
        {1,1},{3,6},{6,7},{9,4},
        {8,1},{4,0},{5,3},{4,2}
    };

    int n = 8;

    printf("Convex Hull Edges:\n");

    for (int i = 0; i < n; i++) {
        for (int j = i + 1; j < n; j++) {

            int pos = 0, neg = 0;

            for (int k = 0; k < n; k++) {

                if (k == i || k == j)
                    continue;

                int val = (p[j].x - p[i].x) * (p[k].y - p[i].y)
                        - (p[j].y - p[i].y) * (p[k].x - p[i].x);

                if (val > 0)
                    pos++;
                else if (val < 0)
                    neg++;
            }

            if (pos == 0 || neg == 0) {
                printf("(%d,%d) -> (%d,%d)\n",
                       p[i].x, p[i].y,
                       p[j].x, p[j].y);
            }
        }
    }

    return 0;
}
